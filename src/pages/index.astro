---
import { getCollection } from "astro:content"
import BaseLayout from "../layouts/BaseLayout.astro"

const news = await getCollection("news");

const latestNews = news.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);
---

<BaseLayout title="Гимназия №4 г. Дзержинский">
	<main>
		<section class="hero">
			<div class="container hero-inner">
				<div>
					<p class="eyebrow">Официальный информационный сайт</p>
					<h1>Гимназия №4 г. Дзержинский</h1>
					<p class="lead">
						Демонстрационная версия сайта
					</p>
					<div class="hero-actions">
						<a class="button" href="/admission/" data-umami-event="home_admission_click">Информация о приёме</a>
						<a class="button secondary" href="/documents/">Документы</a>
					</div>
				</div>
				<div class="card hero-card">
					<h2>Быстрые разделы</h2>
					<ul>
						<li><a href="/news/">Новости Гимназии</a></li>
						<li><a href="/documents/">Документы</a></li>
						<li><a href="/contacts/">Контакты</a></li>
						<li><a href="/privacy/">Персональные данные</a></li>
					</ul>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<h2>Разделы сайта</h2>

				<div class="grid grid-3">
					<article class="card">
						<h3>Родителям</h3>
						<p>Информация о приёме, документах, питании и взаимодействии с гимназией</p>
					</article>

					<article class="card">
						<h3>Ученикам</h3>
						<p>Новости, мероприятия, учебные материалы и полезные объявления</p>
					</article>

					<article class="card">
						<h3>Документы</h3>
						<p>Нормативные документы, локальные акты и материалы образовательной организации</p>
					</article>
				</div>
			</div>
		</section>

		<section class="section news-section">
			<div class="container">
				<div>
					<p class="eyebrow">Последние события</p>
					<h2>Новости Гимназии</h2>
				</div>

				{latestNews.length > 0 ? (
					<div class="grid grid-3">
						{latestNews.map((item) => (
							<article class="card news-card">
								{item.data.image && (
									<img class="news-image" src={item.data.image} alt={item.data.title} />
								)}

								<p class="date">{item.data.pubDate.toLocaleDateString("ru-RU")}</p>
								<h3>{item.data.title}</h3>
								<p>{item.data.description}</p>
								<a class="button" href={`/news/${item.id}/`}>Читать</a>
							</article>
						))}
					</div>
				) : (
					<div class="card">
						<p>Новости пока не добавлены</p>
					</div>
				)}
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="cta card">
					<div>
						<h2>Есть вопрос?</h2>
						<p>На странице контактов размещена форма обратной связи с согласием на обработку персональных данных</p>
					</div>
					
					<a class="button" href="/contacts/">Перейти к контактам</a>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.hero {
		padding: 72px 0;
		background: linear-gradient(135deg, #eaf1ff, #ffffff);
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1.3fr 0.7fr;
		gap: 32px;
		align-items: center;
	}

	.eyebrow {
		color: #2357a4;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	h1 {
		margin: 12px 0;
		font-size: clamp(36px, 6vw, 64px);
		line-height: 1.05;
	}

	h2 {
		margin: 0 0 20px;
		font-size: 32px;
	}

	.lead {
		max-width: 720px;
		font-size: 20px;
		line-height: 1.6;
		color: #4b5875;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.hero-card ul {
		padding-left: 20px;
		line-height: 2;
	}

	.hero-card a {
		color: #2357a4;
		font-weight: 700;
	}

	.news-section {
		background: #ffffff;
	}

	.news-card {
		display: flex;
		flex-direction: column;
	}

	.news-image {
		width: 100%;
		height: 180px;
		object-fit: cover;
		border-radius: 12px;
		margin-bottom: 16px;
		background: #e1e6f0;
	}

	.date {
		margin: 0 0 8px;
		color: #64708a;
		font-size: 14px;
	}

	.news-card h3 {
		margin: 0 0 8px;
	}

	.news-card .button {
		margin-top: auto;
		align-self: flex-start;
	}

	.cta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.cta p {
		margin-bottom: 0;
	}

	@media (max-width: 850px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}

		.cta {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>